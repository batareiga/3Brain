---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getAllPosts } from "../lib/content";

const posts = getAllPosts();
---

<BaseLayout title="Архив" description="Все публикации блога в одном месте.">
  <section class="shell block">
    <div class="section-heading">
      <span class="eyebrow">Архив</span>
      <h1>Все публикации</h1>
      <p>Здесь весь контент без фильтрации. Удобно для обзора и проверки структуры сайта.</p>
    </div>
    <div class="cards">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .block {
    padding-top: 2rem;
  }
</style>
