---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getAllPosts, getRelatedPosts, sectionLabel } from "../../lib/content";
import PostCard from "../../components/PostCard.astro";
import { absoluteUrl } from "../../lib/seo";
import { withBase } from "../../lib/site";

export function getStaticPaths() {
  const posts = getAllPosts();
  return posts.map((post) => {
    const parts = post.slug.split("/");
    return {
      params: {
        section: parts[0],
        slug: parts.slice(1).join("/")
      },
      props: { post, related: getRelatedPosts(post, posts) }
    };
  });
}

const { post, related } = Astro.props;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: post.description,
  datePublished: post.date,
  dateModified: post.updatedAt,
  articleSection: sectionLabel(post.section),
  keywords: post.tags.join(", "),
  mainEntityOfPage: absoluteUrl(post.url)
};
---

<BaseLayout title={post.title} description={post.description} pathname={post.url}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <article class="shell article">
    <header class="article-head">
      <span class="eyebrow">{sectionLabel(post.section)}</span>
      <h1>{post.title}</h1>
      <p>{post.description}</p>
      <div class="meta">
        <span>{formatDate(post.date)}</span>
        <span>{post.readingTime} мин чтения</span>
        <span>{post.relativePath}</span>
      </div>
      {post.tags.length > 0 && (
        <div class="pill-list">
          {post.tags.map((tag) => (
            <a class="pill" href={withBase(`/tags/${tag}/`)}>#{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="article-body panel prose" set:html={post.html} />
  </article>

  {related.length > 0 && (
    <section class="shell related-block">
      <div class="section-heading">
        <span class="eyebrow">Рядом</span>
        <h2>Похожие материалы</h2>
      </div>
      <div class="cards">
        {related.map((item) => (
          <PostCard post={item} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .article {
    display: grid;
    gap: 1.75rem;
    padding-top: 1.35rem;
  }

  .article-head {
    display: grid;
    gap: 1.1rem;
    max-width: 48rem;
  }

  .article-head h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2.35rem, 7vw, 4.7rem);
    line-height: 0.94;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  .article-head p {
    margin: 0;
    color: var(--muted);
    max-width: 42rem;
    font-size: clamp(1.04rem, 1rem + 0.24vw, 1.16rem);
    line-height: 1.65;
    text-wrap: pretty;
  }

  .article-body {
    padding: 1.15rem;
    background:
      linear-gradient(180deg, rgba(255, 248, 232, 0.028), rgba(255, 248, 232, 0.012)),
      var(--panel);
  }

  .related-block {
    padding-top: 3.4rem;
  }

  .article :global(.meta span:last-child) {
    overflow-wrap: anywhere;
  }

  @media (max-width: 759px) {
    .article {
      gap: 1.25rem;
      padding-top: 1rem;
    }

    .article-head {
      gap: 0.95rem;
    }

    .article-body {
      padding: 1rem;
      border-radius: 1.2rem;
    }
  }

  @media (min-width: 900px) {
    .article-body {
      padding: 1.8rem 2rem;
    }
  }
</style>
