---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Страница не найдена" description="Такой страницы здесь нет.">
  <section class="shell lost panel">
    <span class="eyebrow">404</span>
    <h1>Страница не найдена</h1>
    <p>Либо материал ещё не опубликован, либо адрес изменился.</p>
    <a href="/archive/">Перейти в архив</a>
  </section>
</BaseLayout>

<style>
  .lost {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
    padding: 1.8rem;
    place-items: start;
  }

  .lost h1,
  .lost p {
    margin: 0;
  }

  .lost a {
    padding: 0.75rem 1rem;
    border-radius: 999px;
    background: var(--accent);
    color: #151515;
    font-weight: 700;
  }
</style>
