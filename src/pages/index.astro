---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import SectionGrid from "../components/SectionGrid.astro";
import {
  getAllPosts,
  getAllTags,
  getFeaturedPosts,
  getRecentPosts,
  getSections,
  getPostsBySection,
  sectionLabel
} from "../lib/content";
import { withBase } from "../lib/site";

const posts = getAllPosts();
const recent = getRecentPosts(posts, 6);
const featured = getFeaturedPosts(posts, 3);
const sections = getSections(posts);
const averageReadingTime = Math.max(1, Math.round(posts.reduce((sum, post) => sum + post.readingTime, 0) / Math.max(posts.length, 1)));
const topTags = getAllTags(posts)
  .map((tag) => ({ tag, count: posts.filter((post) => post.tags.includes(tag)).length }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 4);
const graphSections = sections.slice(0, 4).map((section, index) => {
  const positions = [
    { x: 20, y: 24 },
    { x: 78, y: 22 },
    { x: 26, y: 76 },
    { x: 80, y: 74 }
  ];
  return {
    section,
    label: sectionLabel(section),
    count: getPostsBySection(section, posts).length,
    ...positions[index]
  };
});
const graphTags = topTags.map((item, index) => {
  const positions = [
    { x: 50, y: 16 },
    { x: 88, y: 48 },
    { x: 50, y: 86 },
    { x: 12, y: 50 }
  ];
  return {
    ...item,
    ...positions[index]
  };
});
const graphEdges = graphSections.flatMap((sectionNode) =>
  graphTags
    .filter((tagNode) => posts.some((post) => post.section === sectionNode.section && post.tags.includes(tagNode.tag)))
    .map((tagNode) => ({ from: sectionNode, to: tagNode }))
);
---

<BaseLayout>
  <section class="shell hero">
    <div class="intro panel">
      <span class="eyebrow">Личный блог разведчика-практика</span>
      <h1>Тихая база знаний для решений, инструментов и рабочих наблюдений.</h1>
      <p>
        Здесь собираются материалы, к которым удобно возвращаться: CLI-инструменты, модели
        заработка, заметки по проектам, идеи, подборки и короткие полевые записи.
      </p>
      <div class="hero-actions">
        <a class="primary" href={withBase("/archive/")}>Открыть архив</a>
        <a class="secondary" href={withBase("/about/")}>Что это за место</a>
      </div>
    </div>
    <div class="hero-side panel">
      <div class="relations-card">
        <div class="relations-head">
          <span class="eyebrow">Карта связей</span>
          <strong>Что с чем связано в базе</strong>
          <p>Разделы соединяются с самыми частыми тегами. Так быстрее видно, где уже собирается плотное знание.</p>
        </div>
        <svg viewBox="0 0 100 100" aria-hidden="true">
          {graphEdges.map((edge) => (
            <line x1={edge.from.x} y1={edge.from.y} x2={edge.to.x} y2={edge.to.y} />
          ))}
          {graphSections.map((node) => (
            <>
              <circle cx={node.x} cy={node.y} r="7.5" />
              <text x={node.x} y={node.y + 14}>{node.label}</text>
            </>
          ))}
          {graphTags.map((node) => (
            <>
              <circle class="tag-node" cx={node.x} cy={node.y} r="5.4" />
              <text class="tag-label" x={node.x} y={node.y + 11}>#{node.tag}</text>
            </>
          ))}
        </svg>
        <div class="relations-stats">
          <div>
            <strong>{graphEdges.length}</strong>
            <i></i>
            <span>связей между разделами и тегами</span>
          </div>
          <div>
            <strong>{posts.length}</strong>
            <i></i>
            <span>материалов в базе</span>
          </div>
          <div>
            <strong>{sections.length}</strong>
            <i></i>
            <span>живых разделов</span>
          </div>
          <div>
            <strong>{averageReadingTime} мин</strong>
            <i></i>
            <span>среднее время чтения записи</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="shell block">
    <div class="section-heading">
      <span class="eyebrow">Лучшее</span>
      <h2>Материалы, с которых стоит начать</h2>
      <p>Если у записи нет явного `featured`, блок сам заполняется свежими сильными публикациями.</p>
    </div>
    <div class="cards">
      {featured.map((post, index) => (
        <PostCard post={post} className={index === 0 ? "span-8" : "span-4"} />
      ))}
    </div>
  </section>

  <section class="shell block">
    <div class="section-heading">
      <span class="eyebrow">Свежее</span>
      <h2>Последние публикации</h2>
      <p>Лента без лишних декораций: дата, время чтения, тема и короткое описание.</p>
    </div>
    <div class="cards">
      {recent.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>

  <section class="shell block">
    <div class="section-heading">
      <span class="eyebrow">Карта тем</span>
      <h2>Разделы базы</h2>
      <p>Каждая папка в `3апасной Мозг. Публикации в интернетах/` автоматически становится разделом сайта.</p>
    </div>
    <SectionGrid sections={sections} />
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    gap: 1rem;
    padding-top: 1rem;
  }

  .intro,
  .hero-side {
    padding: 1.5rem;
  }

  .intro h1 {
    margin: 0.8rem 0 1rem;
    max-width: 13ch;
    font-size: clamp(2.8rem, 8vw, 5.8rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .intro p {
    max-width: 44rem;
    margin: 0;
    color: var(--muted);
    font-size: 1.1rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.5rem;
  }

  .hero-actions a {
    min-height: 3rem;
    padding: 0.8rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--line);
  }

  .primary {
    background: var(--accent);
    color: #161616;
    border-color: transparent;
    font-weight: 700;
  }

  .secondary {
    color: var(--muted);
  }

  .hero-side {
    display: grid;
    gap: 1rem;
    align-content: start;
    min-height: 100%;
  }

  .relations-card {
    display: grid;
    gap: 1rem;
    height: 100%;
    padding: 1.25rem;
    border: 1px solid rgba(216, 173, 98, 0.12);
    border-radius: 1.25rem;
    background:
      radial-gradient(circle at top right, rgba(216, 173, 98, 0.12), transparent 40%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
  }

  .relations-head {
    display: grid;
    gap: 0.35rem;
  }

  .relations-head strong {
    font-size: 1.4rem;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .relations-head p {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .relations-card svg {
    width: 100%;
    height: auto;
    overflow: visible;
    margin: 0.15rem 0 0.25rem;
  }

  .relations-card svg line {
    stroke: rgba(216, 173, 98, 0.24);
    stroke-width: 1.15;
  }

  .relations-card svg circle {
    fill: rgba(216, 173, 98, 0.18);
    stroke: rgba(242, 211, 157, 0.7);
    stroke-width: 0.9;
  }

  .relations-card svg .tag-node {
    fill: rgba(255, 255, 255, 0.07);
    stroke: rgba(255, 255, 255, 0.22);
  }

  .relations-card svg text {
    fill: var(--text);
    font-size: 4px;
    text-anchor: middle;
  }

  .relations-card svg .tag-label {
    fill: var(--muted);
    font-size: 3.2px;
  }

  .relations-stats {
    display: grid;
    gap: 0.75rem;
    margin-top: auto;
  }

  .relations-stats div {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.7rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--line);
  }

  .relations-stats div:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .relations-stats strong {
    font-size: 1.25rem;
    line-height: 1;
    letter-spacing: -0.05em;
    white-space: nowrap;
  }

  .relations-stats span {
    color: var(--muted);
    font-size: 0.95rem;
    text-align: right;
  }

  .relations-stats i {
    height: 1px;
    background: linear-gradient(90deg, rgba(216, 173, 98, 0.18), transparent);
  }

  .block {
    padding-top: 3.8rem;
  }

  @media (min-width: 920px) {
    .hero {
      grid-template-columns: minmax(0, 1.65fr) minmax(280px, 0.75fr);
      align-items: stretch;
    }

    .intro,
    .hero-side {
      padding: 2rem;
    }
  }
</style>
