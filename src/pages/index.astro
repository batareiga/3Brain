---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import SectionGrid from "../components/SectionGrid.astro";
import SearchPanel from "../components/SearchPanel.astro";
import {
  getAllPosts,
  getFeaturedPosts,
  getRecentPosts,
  getSections,
  sectionLabel
} from "../lib/content";
import { withBase } from "../lib/site";

const posts = getAllPosts();
const recent = getRecentPosts(posts, 6);
const featured = getFeaturedPosts(posts, 3);
const sections = getSections(posts);
const chartPosts = [...posts].slice(0, 7).reverse();
const chartValues = chartPosts.map((post, index) => (
  post.readingTime * 16 + post.tags.length * 9 + Math.min(post.title.length, 42) * 0.55 + index * 3
));
const chartMaxReading = Math.max(...chartValues, 1);
const chartPoints = chartPosts
  .map((post, index) => {
    const x = chartPosts.length === 1 ? 50 : (index / (chartPosts.length - 1)) * 100;
    const y = 82 - (chartValues[index] / chartMaxReading) * 46;
    return `${x},${y.toFixed(1)}`;
  })
  .join(" ");
---

<BaseLayout>
  <section class="shell hero">
    <div class="intro panel">
      <span class="eyebrow">Личный блог разведчика-практика</span>
      <h1>Тихая база знаний для решений, инструментов и рабочих наблюдений.</h1>
      <p>
        Здесь собираются материалы, к которым удобно возвращаться: CLI-инструменты, модели
        заработка, заметки по проектам, идеи, подборки и короткие полевые записи.
      </p>
      <div class="hero-actions">
        <a class="primary" href={withBase("/archive/")}>Открыть архив</a>
        <a class="secondary" href={withBase("/about/")}>Что это за место</a>
      </div>
    </div>
    <div class="hero-side panel">
      <div class="signal-card">
        <div class="signal-head">
          <span class="eyebrow">Темп базы</span>
          <strong>Пульс записей</strong>
        </div>
        <svg viewBox="0 0 100 100" aria-hidden="true">
          <defs>
            <linearGradient id="hero-chart-stroke" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="rgba(216, 173, 98, 0.25)" />
              <stop offset="45%" stop-color="rgba(216, 173, 98, 0.9)" />
              <stop offset="100%" stop-color="rgba(242, 211, 157, 0.45)" />
            </linearGradient>
            <linearGradient id="hero-chart-fill" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="rgba(216, 173, 98, 0.28)" />
              <stop offset="100%" stop-color="rgba(216, 173, 98, 0)" />
            </linearGradient>
          </defs>
          <path d={`M 0 90 L 0 82 L ${chartPoints} L 100 82 L 100 90 Z`} />
          <polyline points={chartPoints} />
        </svg>
        <div class="signal-stats">
          <div>
            <strong>{posts.length}</strong>
            <span>материалов в базе</span>
          </div>
          <div>
            <strong>{sections.length}</strong>
            <span>живых направлений</span>
          </div>
          <div>
            <strong>{sectionLabel(sections[0] ?? "notes")}</strong>
            <span>самый свежий раздел</span>
          </div>
        </div>
      </div>
      <SearchPanel
        id="home-search"
        posts={posts}
        compact={true}
        title="Поиск по сайту"
        description="Сразу по заголовкам, описаниям, тегам и разделам."
      />
    </div>
  </section>

  <section class="shell block">
    <div class="section-heading">
      <span class="eyebrow">Лучшее</span>
      <h2>Материалы, с которых стоит начать</h2>
      <p>Если у записи нет явного `featured`, блок сам заполняется свежими сильными публикациями.</p>
    </div>
    <div class="cards">
      {featured.map((post, index) => (
        <PostCard post={post} className={index === 0 ? "span-8" : "span-4"} />
      ))}
    </div>
  </section>

  <section class="shell block">
    <div class="section-heading">
      <span class="eyebrow">Свежее</span>
      <h2>Последние публикации</h2>
      <p>Лента без лишних декораций: дата, время чтения, тема и короткое описание.</p>
    </div>
    <div class="cards">
      {recent.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>

  <section class="shell block">
    <div class="section-heading">
      <span class="eyebrow">Карта тем</span>
      <h2>Разделы базы</h2>
      <p>Каждая папка в `publish/` автоматически становится разделом сайта.</p>
    </div>
    <SectionGrid sections={sections} />
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    gap: 1rem;
    padding-top: 1rem;
  }

  .intro,
  .hero-side {
    padding: 1.5rem;
  }

  .intro h1 {
    margin: 0.8rem 0 1rem;
    max-width: 13ch;
    font-size: clamp(2.8rem, 8vw, 5.8rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .intro p {
    max-width: 44rem;
    margin: 0;
    color: var(--muted);
    font-size: 1.1rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.5rem;
  }

  .hero-actions a {
    min-height: 3rem;
    padding: 0.8rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--line);
  }

  .primary {
    background: var(--accent);
    color: #161616;
    border-color: transparent;
    font-weight: 700;
  }

  .secondary {
    color: var(--muted);
  }

  .hero-side {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .signal-card {
    display: grid;
    gap: 1rem;
    padding: 1.2rem;
    border: 1px solid rgba(216, 173, 98, 0.12);
    border-radius: 1.25rem;
    background:
      radial-gradient(circle at top right, rgba(216, 173, 98, 0.12), transparent 40%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
  }

  .signal-head {
    display: grid;
    gap: 0.35rem;
  }

  .signal-head strong {
    font-size: 1.4rem;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .signal-card svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .signal-card svg path {
    fill: url(#hero-chart-fill);
  }

  .signal-card svg polyline {
    fill: none;
    stroke: url(#hero-chart-stroke);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
    filter: drop-shadow(0 10px 18px rgba(216, 173, 98, 0.15));
  }

  .signal-stats {
    display: grid;
    gap: 0.75rem;
  }

  .signal-stats div {
    display: grid;
    gap: 0.22rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--line);
  }

  .signal-stats div:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .signal-stats strong {
    font-size: 1.55rem;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .signal-stats span {
    color: var(--muted);
  }

  .block {
    padding-top: 3.8rem;
  }

  @media (min-width: 920px) {
    .hero {
      grid-template-columns: minmax(0, 1.65fr) minmax(280px, 0.75fr);
      align-items: stretch;
    }

    .intro,
    .hero-side {
      padding: 2rem;
    }
  }
</style>
