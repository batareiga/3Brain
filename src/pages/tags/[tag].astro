---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getAllPosts, getAllTags, getPostsByTag } from "../../lib/content";

export function getStaticPaths() {
  const posts = getAllPosts();
  return getAllTags(posts).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: getPostsByTag(tag, posts)
    }
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`Публикации с тегом #${tag}.`}>
  <section class="shell block">
    <div class="section-heading">
      <span class="eyebrow">Тег</span>
      <h1>#{tag}</h1>
      <p>Быстрая выборка по тегу без отдельной базы и без индексации во внешнем сервисе.</p>
    </div>
    <div class="cards">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .block {
    padding-top: 2rem;
  }
</style>
