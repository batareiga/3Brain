---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="🔒 Защищённый материал" description="Введите пароль для доступа к секретному руководству" pathname="/tools/black-assembly/">

<div id="lock-screen" class="lock-shell">
  <div class="lock-panel panel">
    <div class="lock-icon">🔒</div>
    <h1>Защищённый материал</h1>
    <p>Это руководство доступно только по паролю. Введите код доступа:</p>
    <form id="unlock-form" class="lock-form">
      <input type="password" id="password-input" placeholder="Пароль" autocomplete="off" spellcheck="false" />
      <button type="submit" id="unlock-btn">Открыть</button>
    </form>
    <div id="error-msg" class="lock-error"></div>
  </div>
</div>

<div id="protected-content" style="display:none">
  <header class="article-head">
    <span class="eyebrow">Секретно</span>
    <h1>Чёрная сборка: как собрать что угодно из ничего</h1>
    <div class="meta">
      <span>Июнь 2026</span>
      <span>~30 мин чтения</span>
    </div>
  </header>
  <div id="decrypted-body" class="ba-content"></div>
</div>

</BaseLayout>

<style is:global>
  /* ===== LOCK SCREEN ===== */
  .lock-shell {
    display: flex; align-items: center; justify-content: center;
    min-height: 70vh; padding: 2rem 1rem;
  }
  .lock-panel {
    max-width: 420px; width: 100%; padding: 2.5rem 2rem;
    text-align: center; display: grid; gap: 1.2rem;
  }
  .lock-icon { font-size: 3rem; line-height: 1; }
  .lock-panel h1 { margin: 0; font-size: 1.6rem; }
  .lock-panel p { margin: 0; color: var(--muted, #999); font-size: 0.95rem; }
  .lock-form { display: grid; gap: 0.8rem; margin-top: 0.5rem; }
  .lock-form input {
    padding: 0.85rem 1rem; border: 1px solid var(--line, #333);
    border-radius: 0.75rem; background: rgba(255,255,255,0.04);
    color: var(--text, #e0e0e0); font-size: 1.1rem;
    text-align: center; letter-spacing: 0.15em;
    outline: none; transition: border-color 0.2s;
  }
  .lock-form input:focus { border-color: var(--accent, #d8ad62); }
  .lock-form button {
    padding: 0.85rem 1rem; border: none; border-radius: 0.75rem;
    background: var(--accent, #d8ad62); color: #161616;
    font-size: 1rem; font-weight: 700; cursor: pointer;
    transition: opacity 0.2s;
  }
  .lock-form button:hover { opacity: 0.88; }
  .lock-form button:disabled { opacity: 0.4; cursor: not-allowed; }
  .lock-error { color: #e74c3c; font-size: 0.88rem; min-height: 1.3rem; }

  /* ===== ARTICLE LAYOUT ===== */
  #protected-content {
    display: grid; gap: 1rem;
    margin: 0 auto;
    width: 100%;
    max-width: 100%;
    /* CRITICAL: prevent grid children from overflowing */
    min-width: 0;
  }

  .article-head {
    display: grid; gap: 0.5rem;
    max-width: 100%;
    min-width: 0;
  }
  .article-head h1 {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.08;
    letter-spacing: -0.03em;
    word-break: break-word;
    overflow-wrap: break-word;
  }
  .meta {
    display: flex; gap: 0.5rem; flex-wrap: wrap;
    color: var(--muted, #999); font-size: 0.8rem;
  }

  /* ===== DECRYPTED BODY — innerHTML ===== */
  #decrypted-body.ba-content {
    max-width: 100% !important;
    width: 100%;
    min-width: 0;
    /* overflow-x clips anything that escapes */
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    padding: 0;
    background: none;
    font-size: 0.9rem;
    line-height: 1.6;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  #decrypted-body.ba-content h1,
  #decrypted-body.ba-content h2,
  #decrypted-body.ba-content h3 {
    margin: 1.1em 0 0.45em;
    line-height: 1.2;
    font-weight: 700;
  }
  #decrypted-body.ba-content h1 { font-size: 1.3rem; }
  #decrypted-body.ba-content h2 { font-size: 1.1rem; }
  #decrypted-body.ba-content h3 { font-size: 1rem; }
  #decrypted-body.ba-content p { margin: 0.5em 0; }
  #decrypted-body.ba-content blockquote {
    margin: 0.6rem 0;
    padding: 0.4rem 0.6rem;
    border-left: 3px solid var(--accent, #d8ad62);
    background: rgba(255,255,255,0.025);
    border-radius: 0 0.35rem 0.35rem 0;
    color: var(--muted, #bbb);
    font-style: italic;
    font-size: 0.88rem;
  }
  #decrypted-body.ba-content ul,
  #decrypted-body.ba-content ol {
    padding-left: 1.1rem;
    margin: 0.4rem 0;
  }
  #decrypted-body.ba-content li { margin: 0.2rem 0; }
  #decrypted-body.ba-content hr {
    border: none;
    border-top: 1px solid var(--line, #333);
    margin: 1rem 0;
  }
  #decrypted-body.ba-content a {
    color: var(--accent, #d8ad62);
    text-decoration: underline;
    word-break: break-all;
  }
  #decrypted-body.ba-content img {
    max-width: 100% !important;
    height: auto;
    border-radius: 0.5rem;
    margin: 0.8rem 0;
  }
  #decrypted-body.ba-content pre {
    overflow-x: auto;
    max-width: 100%;
    font-size: 0.78rem;
    padding: 0.7rem;
    border-radius: 0.5rem;
    background: rgba(0,0,0,0.2);
    line-height: 1.35;
    margin: 0.6rem 0;
  }
  #decrypted-body.ba-content code {
    font-size: 0.78rem;
    word-break: break-all;
  }
  #decrypted-body.ba-content pre code {
    word-break: normal;
  }

  /* ===== TABLES — CRITICAL FIXES ===== */
  #decrypted-body.ba-content table {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
    margin: 0.8rem 0;
    word-break: break-word;
    overflow-wrap: break-word;
    /* Don't force single-line — allow wrapping */
    white-space: normal;
  }
  #decrypted-body.ba-content table th {
    background: rgba(255,255,255,0.05);
    padding: 0.35rem 0.4rem;
    border: 1px solid var(--line, #333);
    text-align: left;
    font-weight: 700;
  }
  #decrypted-body.ba-content table td {
    padding: 0.3rem 0.4rem;
    border: 1px solid var(--line, #333);
    vertical-align: top;
  }
  #decrypted-body.ba-content table tr:nth-child(even) {
    background: rgba(255,255,255,0.02);
  }

  /* ===== DESKTOP ===== */
  @media (min-width: 768px) {
    #protected-content {
      gap: 1.5rem;
      max-width: 860px;
    }
    .article-head { gap: 0.7rem; }
    .article-head h1 { font-size: 2.2rem; }
    .meta { font-size: 0.85rem; }
    #decrypted-body.ba-content {
      padding: 1.5rem 1.8rem;
      background:
        linear-gradient(180deg, rgba(255, 248, 232, 0.03), rgba(255, 248, 232, 0.01)),
        var(--panel, #1a1a1e);
      border-radius: 1rem;
      font-size: 0.95rem;
      line-height: 1.7;
      overflow-x: visible;
    }
    #decrypted-body.ba-content h1 { font-size: 1.6rem; }
    #decrypted-body.ba-content h2 { font-size: 1.3rem; }
    #decrypted-body.ba-content h3 { font-size: 1.1rem; }
    #decrypted-body.ba-content table {
      font-size: 0.85rem;
      white-space: nowrap;
    }
    #decrypted-body.ba-content table th,
    #decrypted-body.ba-content table td { padding: 0.45rem 0.6rem; }
    #decrypted-body.ba-content pre,
    #decrypted-body.ba-content code { font-size: 0.85rem; }
  }

  @media (min-width: 1000px) {
    #protected-content { max-width: 920px; }
  }
</style>

<script>
const PWD_HASH = "277b88d938b4664046a5870ad3cbd6eb55795b447d05ee580a5de5b919e5affc";
const B64_PAYLOAD = ``;

function b64ToBytes(b64) {
  return Uint8Array.from(atob(b64), c => c.charCodeAt(0));
}

const ENCRYPTED = JSON.parse(atob(B64_PAYLOAD));
const SALT = b64ToBytes(ENCRYPTED.salt);
const IV = b64ToBytes(ENCRYPTED.iv);
const TAG = b64ToBytes(ENCRYPTED.tag);
const DATA = b64ToBytes(ENCRYPTED.data);

const els = {
  lock: document.getElementById("lock-screen"),
  content: document.getElementById("protected-content"),
  body: document.getElementById("decrypted-body"),
  form: document.getElementById("unlock-form"),
  input: document.getElementById("password-input"),
  btn: document.getElementById("unlock-btn"),
  error: document.getElementById("error-msg")
};

function sha256(str) {
  return crypto.subtle.digest("SHA-256", new TextEncoder().encode(str))
    .then(hash => Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2, "0")).join(""));
}

async function decryptContent(password) {
  const keyMaterial = await crypto.subtle.importKey(
    "raw", new TextEncoder().encode(password),
    "PBKDF2", false, ["deriveKey"]
  );
  const key = await crypto.subtle.deriveKey(
    { name: "PBKDF2", salt: SALT, iterations: 100000, hash: "SHA-256" },
    keyMaterial,
    { name: "AES-GCM", length: 256 },
    false,
    ["decrypt"]
  );
  const encrypted = new Uint8Array([...DATA, ...TAG]);
  const decrypted = await crypto.subtle.decrypt(
    { name: "AES-GCM", iv: IV },
    key,
    encrypted
  );
  return new TextDecoder().decode(decrypted);
}

els.form.addEventListener("submit", async (e) => {
  e.preventDefault();
  const pw = els.input.value.trim();
  if (!pw) { els.error.textContent = "Введите пароль"; return; }
  els.btn.disabled = true; els.btn.textContent = "Проверка..."; els.error.textContent = "";
  try {
    if (await sha256(pw) !== PWD_HASH) {
      els.error.textContent = "Неверный пароль";
      els.btn.disabled = false; els.btn.textContent = "Открыть";
      return;
    }
    els.body.innerHTML = await decryptContent(pw);
    els.lock.style.display = "none";
    els.content.style.display = "grid";
  } catch (err) {
    console.error(err);
    els.error.textContent = "Ошибка расшифровки";
    els.btn.disabled = false; els.btn.textContent = "Открыть";
  }
});
</script>