---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="🔒 Защищённый материал" description="Введите пароль для доступа к секретному руководству" pathname="/tools/black-assembly/">

<div id="lock-screen" class="lock-shell">
  <div class="lock-panel panel">
    <div class="lock-icon">🔒</div>
    <h1>Защищённый материал</h1>
    <p>Это руководство доступно только по паролю. Введите код доступа:</p>
    <form id="unlock-form" class="lock-form">
      <input type="password" id="password-input" placeholder="Пароль" autocomplete="off" spellcheck="false" />
      <button type="submit" id="unlock-btn">Открыть</button>
    </form>
    <div id="error-msg" class="lock-error"></div>
  </div>
</div>

<div id="protected-content" class="shell article" style="display:none">
  <article class="shell article">
    <header class="article-head">
      <span class="eyebrow">Секретно</span>
      <h1>Чёрная сборка: как собрать что угодно из ничего</h1>
      <div class="meta">
        <span>Июнь 2026</span>
        <span>~30 мин чтения</span>
      </div>
    </header>
    <div id="decrypted-body" class="article-body panel prose"></div>
  </article>
</div>

</BaseLayout>

<style>
  .lock-shell { display: flex; align-items: center; justify-content: center; min-height: 70vh; padding: 2rem 1rem; }
  .lock-panel { max-width: 420px; width: 100%; padding: 2.5rem 2rem; text-align: center; display: grid; gap: 1.2rem; }
  .lock-icon { font-size: 3rem; line-height: 1; }
  .lock-panel h1 { margin: 0; font-size: 1.6rem; }
  .lock-panel p { margin: 0; color: var(--muted, #999); font-size: 0.95rem; }
  .lock-form { display: grid; gap: 0.8rem; margin-top: 0.5rem; }
  .lock-form input { padding: 0.85rem 1rem; border: 1px solid var(--line, #333); border-radius: 0.75rem; background: rgba(255,255,255,0.04); color: var(--text, #e0e0e0); font-size: 1.1rem; text-align: center; letter-spacing: 0.15em; outline: none; transition: border-color 0.2s; }
  .lock-form input:focus { border-color: var(--accent, #d8ad62); }
  .lock-form button { padding: 0.85rem 1rem; border: none; border-radius: 0.75rem; background: var(--accent, #d8ad62); color: #161616; font-size: 1rem; font-weight: 700; cursor: pointer; transition: opacity 0.2s; }
  .lock-form button:hover { opacity: 0.88; }
  .lock-form button:disabled { opacity: 0.4; cursor: not-allowed; }
  .lock-error { color: #e74c3c; font-size: 0.88rem; min-height: 1.3rem; }
  .article { display: grid; gap: 1.75rem; padding-top: 1.35rem; }
  .article-head { display: grid; gap: 1.1rem; max-width: 48rem; }
  .article-head h1 { margin: 0; max-width: 14ch; font-size: clamp(2.35rem, 7vw, 4.7rem); line-height: 0.94; letter-spacing: -0.06em; text-wrap: balance; }
  .article-body { padding: 1.8rem 2rem; background: linear-gradient(180deg, rgba(255, 248, 232, 0.028), rgba(255, 248, 232, 0.012)), var(--panel, #1a1a1e); }
  .meta { display: flex; gap: 1rem; flex-wrap: wrap; color: var(--muted, #999); font-size: 0.9rem; }
  @media (max-width: 759px) { .article { gap: 1.25rem; padding-top: 1rem; } .article-body { padding: 1rem; border-radius: 1.2rem; } }
  @media (min-width: 900px) { .article-body { padding: 1.8rem 2rem; } }
</style>

<script>
const PWD_HASH = "277b88d938b4664046a5870ad3cbd6eb55795b447d05ee580a5de5b919e5affc";
const B64_PAYLOAD = ``;

function b64ToBytes(b64) {
  return Uint8Array.from(atob(b64), c => c.charCodeAt(0));
}

const ENCRYPTED = JSON.parse(atob(B64_PAYLOAD));
const SALT = b64ToBytes(ENCRYPTED.salt);
const IV = b64ToBytes(ENCRYPTED.iv);
const TAG = b64ToBytes(ENCRYPTED.tag);
const DATA = b64ToBytes(ENCRYPTED.data);

const lockScreen = document.getElementById("lock-screen");
const protectedContent = document.getElementById("protected-content");
const decryptedBody = document.getElementById("decrypted-body");
const form = document.getElementById("unlock-form");
const input = document.getElementById("password-input");
const btn = document.getElementById("unlock-btn");
const errorMsg = document.getElementById("error-msg");

function sha256(str) {
  return crypto.subtle.digest("SHA-256", new TextEncoder().encode(str))
    .then(hash => Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2, "0")).join(""));
}

async function decryptContent(password) {
  const keyMaterial = await crypto.subtle.importKey(
    "raw", new TextEncoder().encode(password),
    "PBKDF2", false, ["deriveKey"]
  );
  const key = await crypto.subtle.deriveKey(
    { name: "PBKDF2", salt: SALT, iterations: 100000, hash: "SHA-256" },
    keyMaterial,
    { name: "AES-GCM", length: 256 },
    false,
    ["decrypt"]
  );
  const encrypted = new Uint8Array([...DATA, ...TAG]);
  const decrypted = await crypto.subtle.decrypt(
    { name: "AES-GCM", iv: IV },
    key,
    encrypted
  );
  return new TextDecoder().decode(decrypted);
}

form.addEventListener("submit", async (e) => {
  e.preventDefault();
  const password = input.value.trim();
  if (!password) { errorMsg.textContent = "Введите пароль"; return; }

  btn.disabled = true;
  btn.textContent = "Проверка...";
  errorMsg.textContent = "";

  try {
    const hash = await sha256(password);
    if (hash !== PWD_HASH) {
      errorMsg.textContent = "Неверный пароль";
      btn.disabled = false;
      btn.textContent = "Открыть";
      return;
    }
    const html = await decryptContent(password);
    decryptedBody.innerHTML = html;
    lockScreen.style.display = "none";
    protectedContent.style.display = "grid";
    sessionStorage.setItem("black-assembly-unlocked", "true");
  } catch (err) {
    console.error("Decrypt error:", err);
    errorMsg.textContent = "Ошибка расшифровки. Проверьте пароль.";
    btn.disabled = false;
    btn.textContent = "Открыть";
  }
});
</script>