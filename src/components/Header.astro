---
import { withBase } from "../lib/site";

const nav = [
  { href: withBase("/"), label: "Главная" },
  { href: withBase("/archive/"), label: "Архив" },
  { href: withBase("/about/"), label: "О проекте" }
];
---

<header class="site-header">
  <div class="shell bar">
    <a class="brand" href={withBase("/")}>
      <span class="brand-mark" aria-hidden="true">3B</span>
      <span class="brand-copy">
        <strong>3Brain</strong>
        <small>Запасной Мозг</small>
      </span>
    </a>
    <nav>
      {nav.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    padding: 1rem 1.25rem 0;
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(10, 11, 12, 0.45);
    backdrop-filter: blur(16px);
    position: sticky;
    top: 1rem;
    z-index: 10;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    min-width: 0;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 2.7rem;
    aspect-ratio: 1;
    border-radius: 0.95rem;
    border: 1px solid rgba(216, 173, 98, 0.2);
    background:
      radial-gradient(circle at top left, rgba(242, 211, 157, 0.3), transparent 55%),
      linear-gradient(145deg, rgba(216, 173, 98, 0.2), rgba(255, 255, 255, 0.03));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 10px 24px rgba(0, 0, 0, 0.22);
    color: var(--accent-soft);
    font-size: 0.98rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .brand-copy {
    display: grid;
    gap: 0.06rem;
    min-width: 0;
  }

  .brand-copy strong {
    font-size: 1rem;
    line-height: 1;
    letter-spacing: -0.05em;
    background: linear-gradient(180deg, #fff5df 0%, #d8ad62 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .brand-copy strong::after {
    content: "";
    display: block;
    width: 100%;
    height: 1px;
    margin-top: 0.22rem;
    background: linear-gradient(90deg, rgba(216, 173, 98, 0.42), transparent);
  }

  .brand-copy small {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.9rem;
  }

  nav a {
    color: var(--muted);
  }

  nav a:hover {
    color: var(--text);
  }

  @media (max-width: 720px) {
    .bar {
      border-radius: 1.2rem;
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
