---
import { withBase } from "../lib/site";
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <p>
      Запасной Мозг. Практичные материалы без витринного шума.
    </p>
    <div class="links">
      <a href={withBase("/rss.xml")}>RSS</a>
      <a href={withBase("/archive/")}>Архив</a>
      <a href={withBase("/about/")}>О проекте</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 0 1.25rem 2rem;
  }

  .footer-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.2rem 1.4rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
  }

  .footer-grid p {
    margin: 0;
  }

  .links {
    display: flex;
    gap: 1rem;
  }
  .links a:hover {
    color: var(--text);
  }
</style>
