---
import type { Post } from "../lib/content";
import { formatDate, sectionLabel } from "../lib/content";

type Props = {
  post: Post;
  className?: string;
};

const { post, className = "span-4" } = Astro.props;
---

<article class={`card panel ${className}`}>
  <div class="meta">
    <span>{sectionLabel(post.section)}</span>
    <span>{formatDate(post.date)}</span>
    <span>{post.readingTime} мин</span>
  </div>
  <h3><a href={post.url}>{post.title}</a></h3>
  <p>{post.description}</p>
  {post.tags.length > 0 && (
    <div class="tags">
      {post.tags.slice(0, 3).map((tag) => (
        <a class="pill" href={`/tags/${tag}/`}>#{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .card {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
    min-height: 100%;
  }

  h3 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: auto;
  }
</style>
