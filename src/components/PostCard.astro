---
import type { Post } from "../lib/content";
import { formatDate, sectionLabel } from "../lib/content";
import { withBase } from "../lib/site";

type Props = {
  post: Post;
  className?: string;
};

const { post, className = "span-4" } = Astro.props;
---

<article class={`card panel ${className}`}>
  <div class="meta">
    <span>{sectionLabel(post.section)}</span>
    <span>{formatDate(post.date)}</span>
    <span>{post.readingTime} мин</span>
  </div>
  <h3><a href={post.url}>{post.title}</a></h3>
  <p>{post.description}</p>
  {post.tags.length > 0 && (
    <div class="tags">
      {post.tags.slice(0, 3).map((tag) => (
        <a class="pill" href={withBase(`/tags/${tag}/`)}>#{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .card {
    display: grid;
    gap: 0.9rem;
    padding: 1.25rem;
    min-height: 100%;
    align-content: start;
    background:
      linear-gradient(180deg, rgba(255, 248, 232, 0.03), rgba(255, 248, 232, 0.015)),
      var(--panel);
    transition: border-color 180ms ease, background-color 180ms ease, box-shadow 180ms ease;
  }

  .card:hover {
    border-color: rgba(216, 173, 98, 0.24);
    background:
      linear-gradient(180deg, rgba(255, 248, 232, 0.045), rgba(255, 248, 232, 0.02)),
      var(--panel);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.22);
  }

  h3 {
    margin: 0;
    font-size: clamp(1.22rem, 1.1rem + 0.4vw, 1.5rem);
    line-height: 1.12;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  p {
    margin: 0;
    color: var(--muted);
    font-size: 0.98rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: auto;
  }

  @media (min-width: 760px) {
    .card {
      padding: 1.35rem;
    }
  }
</style>
