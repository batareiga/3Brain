---
import type { Post } from "../lib/content";
import { formatDate, sectionLabel } from "../lib/content";

type Props = {
  id: string;
  posts: Post[];
  eyebrow?: string;
  title?: string;
  description?: string;
  compact?: boolean;
  limit?: number;
  showInitialResults?: boolean;
  minimal?: boolean;
  floatingResults?: boolean;
};

const {
  id,
  posts,
  eyebrow = "Поиск",
  title = "Найти по базе",
  description = "Поиск по заголовкам, описаниям, тегам и разделам.",
  compact = false,
  limit = compact ? 4 : 12,
  showInitialResults = true,
  minimal = false,
  floatingResults = false
} = Astro.props;

const items = posts.map((post) => ({
  url: post.url,
  title: post.title,
  description: post.description,
  section: sectionLabel(post.section),
  tags: post.tags,
  date: formatDate(post.date),
  readingTime: post.readingTime,
  search: [post.title, post.description, sectionLabel(post.section), ...post.tags].join(" ").toLowerCase()
}));
---

<section
  class:list={[
    "search-panel panel",
    compact && "compact",
    minimal && "minimal",
    floatingResults && "floating-results"
  ]}
  data-search-root
  data-limit={limit}
  data-show-initial-results={showInitialResults ? "true" : "false"}
>
  {!minimal && (
    <div class="search-copy">
      <span class="eyebrow">{eyebrow}</span>
      <h2>{title}</h2>
      <p>{description}</p>
    </div>
  )}

  <label class="search-input" for={`${id}-search`}>
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M10.5 4.75a5.75 5.75 0 1 0 0 11.5a5.75 5.75 0 0 0 0-11.5Zm0-1.5a7.25 7.25 0 1 1 4.56 12.88l4.41 4.42l-1.06 1.06L14 17.2a7.25 7.25 0 0 1-3.5.9Z"
      />
    </svg>
    <input
      id={`${id}-search`}
      type="search"
      placeholder={minimal ? "Поиск по базе" : "Например: cli, деньги, проект"}
      autocomplete="off"
    />
  </label>

  <div class:list={["search-summary", (minimal || floatingResults) && "summary-hidden"]} data-search-summary>
    {showInitialResults ? `Показаны все материалы: ${items.length}` : "Начните вводить запрос"}
  </div>

  <div class="search-results" data-search-results>
    {showInitialResults && items.slice(0, limit).map((item) => (
      <a class="search-result" href={item.url}>
        <span class="result-meta">
          <span>{item.section}</span>
          <span>{item.date}</span>
          <span>{item.readingTime} мин</span>
        </span>
        <strong>{item.title}</strong>
        <span class="result-description">{item.description}</span>
      </a>
    ))}
  </div>

  <template data-search-empty>
    <div class="search-empty">Ничего не найдено.</div>
  </template>

  <script type="application/json" data-search-data set:html={JSON.stringify(items)} />
</section>

<script is:inline>
  document.querySelectorAll("[data-search-root]").forEach((root) => {
    if (root.dataset.bound === "true") return;
    root.dataset.bound = "true";

    const input = root.querySelector("input");
    const results = root.querySelector("[data-search-results]");
    const summary = root.querySelector("[data-search-summary]");
    const emptyTemplate = root.querySelector("[data-search-empty]");
    const dataNode = root.querySelector("[data-search-data]");
    const limit = Number(root.dataset.limit || "10");
    const showInitialResults = root.dataset.showInitialResults === "true";

    if (!input || !results || !summary || !emptyTemplate || !dataNode?.textContent) return;

    const items = JSON.parse(dataNode.textContent);
    const render = (query) => {
      const normalized = query.trim().toLowerCase();
      if (!normalized && !showInitialResults) {
        summary.textContent = "Начните вводить запрос";
        results.innerHTML = "";
        return;
      }

      const filtered = normalized
        ? items.filter((item) => item.search.includes(normalized))
        : items;

      const visible = filtered.slice(0, limit);
      summary.textContent = normalized
        ? `Найдено: ${filtered.length}`
        : `Показаны все материалы: ${items.length}`;

      if (visible.length === 0) {
        results.innerHTML = emptyTemplate.innerHTML;
        return;
      }

      results.innerHTML = visible
        .map(
          (item) => `
            <a class="search-result" href="${item.url}">
              <span class="result-meta">
                <span>${item.section}</span>
                <span>${item.date}</span>
                <span>${item.readingTime} мин</span>
              </span>
              <strong>${item.title}</strong>
              <span class="result-description">${item.description}</span>
            </a>
          `
        )
        .join("");
    };

    input.addEventListener("input", (event) => {
      render(event.currentTarget.value);
    });

    input.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        input.value = "";
        render("");
        input.blur();
      }
    });
  });
</script>

<style>
  .search-panel {
    display: grid;
    gap: 1rem;
    padding: 1.3rem;
  }

  .search-copy {
    display: grid;
    gap: 0.35rem;
  }

  .search-copy h2 {
    margin: 0;
    font-size: clamp(1.2rem, 1rem + 0.6vw, 1.75rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .search-copy p,
  .search-summary,
  .search-result > span,
  .search-empty {
    color: var(--muted);
  }

  .search-copy p,
  .search-summary {
    margin: 0;
    font-size: 0.96rem;
  }

  .search-input {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 3.25rem;
    padding: 0.8rem 1rem;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.035);
  }

  .search-input svg {
    width: 1.1rem;
    height: 1.1rem;
    fill: var(--muted);
    flex: none;
  }

  .search-input input {
    width: 100%;
    border: 0;
    outline: 0;
    padding: 0;
    color: var(--text);
    background: transparent;
    font: inherit;
  }

  .search-input input::placeholder {
    color: color-mix(in srgb, var(--muted) 80%, transparent);
  }

  .search-results {
    display: grid;
    gap: 0.75rem;
  }

  .search-result,
  .search-empty {
    display: grid;
    gap: 0.45rem;
    padding: 0.95rem 1rem;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.025);
  }

  .search-result:hover {
    border-color: rgba(216, 173, 98, 0.26);
    background: rgba(255, 255, 255, 0.045);
  }

  .search-result strong {
    font-size: 1rem;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .result-description {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .result-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.8rem;
    font-size: 0.83rem;
  }

  .compact {
    padding: 1.15rem;
  }

  .compact .search-copy h2 {
    font-size: 1.1rem;
  }

  .compact .search-copy p {
    font-size: 0.9rem;
  }

  .minimal {
    position: relative;
    padding: 0;
    width: min(100%, 18.5rem);
    min-width: 15rem;
    isolation: isolate;
    border-radius: 999px;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  .minimal .search-input {
    min-height: 2.85rem;
    border-radius: 999px;
    border-color: rgba(255, 248, 232, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .minimal .search-input:focus-within {
    border-color: rgba(216, 173, 98, 0.28);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: 0 0 0 4px rgba(216, 173, 98, 0.08);
  }

  .minimal .search-summary {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    font-size: 0.84rem;
    opacity: 0;
    pointer-events: none;
  }

  .minimal .search-results {
    position: absolute;
    top: calc(100% + 0.7rem);
    right: 0;
    width: min(26rem, 92vw);
    max-height: min(65vh, 28rem);
    overflow-y: auto;
    padding: 0.5rem;
    border: 1px solid rgba(255, 248, 232, 0.1);
    border-radius: 1.15rem;
    background: rgba(12, 14, 16, 0.98);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.42);
    backdrop-filter: blur(18px);
    z-index: 20;
  }

  .minimal .search-results:empty {
    display: none;
  }

  .minimal .search-result,
  .minimal .search-empty {
    box-shadow: none;
    backdrop-filter: none;
    background: rgba(255, 255, 255, 0.025);
  }

  .minimal .search-result {
    gap: 0.32rem;
    padding: 0.82rem 0.95rem;
  }

  .minimal .search-result strong {
    font-size: 0.95rem;
  }

  .minimal .result-meta {
    gap: 0.35rem 0.6rem;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .minimal .result-description {
    display: none;
  }

  .summary-hidden {
    display: none;
  }

  .floating-results {
    position: relative;
  }

  .floating-results .search-results {
    position: absolute;
    top: calc(100% - 0.15rem);
    left: 0;
    right: 0;
    z-index: 20;
    max-height: min(60vh, 24rem);
    overflow-y: auto;
    padding-top: 0.75rem;
  }

  .floating-results .search-results:empty {
    display: none;
  }

  .floating-results .search-result,
  .floating-results .search-empty {
    box-shadow: var(--shadow);
    backdrop-filter: blur(14px);
    background: rgba(18, 20, 22, 0.96);
  }

  @media (max-width: 720px) {
    .minimal {
      width: 100%;
      min-width: 0;
    }

    .minimal .search-results {
      width: 100%;
      right: auto;
      left: 0;
    }

    .floating-results .search-results {
      max-height: 20rem;
    }
  }
</style>
